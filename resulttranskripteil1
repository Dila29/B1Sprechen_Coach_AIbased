<script>
  const params = new URLSearchParams(window.location.search);
  const submissionId = params.get("submission_id");

  const sheetUrl = "https://opensheet.elk.sh/1blJ08Su-RC3Ld9Ti3g72RbYpd-9vwHy1XoyQv-UiEek/Transkript%20Result%20B1%20Sprechen%20-%20Teil%201";

  function formatParagraphs(text) {
    return (text || "")
      .split("\n")
      .filter(line => line.trim() !== "")
      .map(line => `<p>${line}</p>`)
      .join("");
  }

  function extractParticipants(transcript) {
    if (!transcript) {
      return ["Teilnehmer A", "Teilnehmer B"];
    }

    const lines = transcript.split("\n");
    const names = [];

    for (const line of lines) {
      const match = line.match(/^\s*([^:]+)\s*:/);
      if (match) {
        const name = match[1].trim();
        if (name && !names.includes(name)) {
          names.push(name);
        }
      }
      if (names.length >= 2) break;
    }

    return [
      names[0] || "Teilnehmer A",
      names[1] || "Teilnehmer B"
    ];
  }

  async function fetchResults() {
    const status = document.getElementById("status");

    try {
      const response = await fetch(sheetUrl);
      const data = await response.json();

      const result = data.find(
        row => String(row["Submission ID"]) === String(submissionId)
      );

      if (result && result["Response"]) {
        const transcript =
          result["Typen Sie Ihre Diskusion/Planung/Dialog (Transkripte) Hier"] || "-";

        const [participantA, participantB] = extractParticipants(transcript);

        document.getElementById("participantA").innerText = participantA;
        document.getElementById("participantB").innerText = participantB;

        document.getElementById("task").innerText =
          result["Situation wählen"] || "-";

        document.getElementById("transcript").innerText = transcript;

        const feedbackText = result["Response"] || "";
        document.getElementById("feedback").innerHTML = formatParagraphs(feedbackText);

        setTimeout(() => {
          document.getElementById("status").classList.add("hidden");
          document.getElementById("result").classList.remove("hidden");
        }, 1000);

      } else {
        status.innerHTML = `
          <div class="text-center space-y-4">
            <span class="material-symbols-outlined text-primary text-5xl animate-spin">psychology</span>
            <p class="text-on-surface/70">Analyse läuft noch... Die Seite wird automatisch aktualisiert.</p>
          </div>
        `;
        setTimeout(fetchResults, 5000);
      }

    } catch (error) {
      status.innerHTML = `
        <div class="text-center text-error space-y-2">
          <p class="text-lg font-bold">Fehler beim Laden der Analyse.</p>
          <p class="text-sm">Bitte prüfen Sie die Sheet-URL und die Spaltennamen.</p>
        </div>
      `;
      console.error(error);
    }
  }

  fetchResults();
</script>
